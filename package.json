{
	"name": "return-all",
	"version": "0.2.1",
	"sideEffects": false,
	"description": "Merge the return values of multiple functions into a single typed object",
	"keywords": [
		"typescript",
		"merge",
		"spread",
		"return",
		"types",
		"utility"
	],
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint": "eslint src",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:cov": "vitest run --coverage",
		"typecheck": "tsc --noEmit",
		"pub": "pnpm publish --no-git-checks",
		"prepub": "pnpm run typecheck && pnpm run build",
		"release:patch": "pnpm version patch --no-git-tag-version && pnpm run pub",
		"release:minor": "pnpm version minor --no-git-tag-version && pnpm run pub",
		"release:major": "pnpm version major --no-git-tag-version && pnpm run pub"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@vitest/coverage-v8": "^4.1.2",
		"eslint": "^10.1.0",
		"jiti": "^2.6.1",
		"prettier": "^3.8.1",
		"tsup": "^8.0.0",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.58.0",
		"vitest": "^4.1.2"
	}
}
