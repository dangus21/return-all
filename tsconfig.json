{
	"compileOnSave": false,
	"compilerOptions": {
		"allowJs": false,
		"allowSyntheticDefaultImports": true,
		"declaration": false,
		"esModuleInterop": true,
		"importHelpers": true,
		"jsx": "react-jsx",
		"jsxImportSource": "react",
		"lib": [
			"ES2022",
			"DOM",
			"DOM.Iterable"
		],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"noUncheckedIndexedAccess": true,
		"noErrorTruncation": true,
		"resolveJsonModule": true,
		"rootDir": "./",
		"skipDefaultLibCheck": true,
		"skipLibCheck": true,
		"sourceMap": true,
		"noEmit": true,
		"strict": true,
		"target": "ES2022",
	},
	"include": [
		"eslint.config.mjs",
		"src/**/*"
	],
	"exclude": [
		"**/node_modules"
	]
}
